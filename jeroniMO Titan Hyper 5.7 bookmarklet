et i=0; i<8; i++) p.push({x: Math.random()*c.width, y: Math.random()*c.height, s: 2, c: %27#ffaa00'});            ctx.fillStyle = 'rgba(0,0,0,0.05)'; ctx.fillRect(0,0,c.width,c.height);            p.forEach(it => {                ctx.fillStyle = it.c; ctx.fillRect(it.x, it.y, it.s, it.s);                it.s += 4; it.x += (Math.random()-0.5)*10;                if(it.s > 150) p.shift();            });        }, 40);    }    /* --- THE ABSOLUTE AUTHENTICATION OVERRIDE --- */    async function startAuth() {        const savedUser = localStorage.getItem('jM_user');        if(savedUser && savedUser !== "Guest") {            const data = await bridgeRead(DB_URL + "users/" + savedUser + ".json");            if(data) { currentUser = String(savedUser); userPfp = data.pfp || userPfp; vaultContent = data.vault || ""; runBoot(); return; }        }        const mode = prompt("🔱 jeroniMO v5.2 OMEGA TITAN [RE-CORE]\n\n1. Login (Secure Handshake)\n2. Register New Identity\n3. Guest Access\n4. FORCE BYPASS (If Login Fails)\n5. TOTAL SYSTEM PURGE");        if(mode === '5') { localStorage.clear(); alert("TITAN CACHE PURGED."); location.reload(); return; }        if(mode === '4') {            if(prompt("BYPASS KEY:") === "LOGIN.SYS") {                const u = prompt("Enter Identity to Force-Load:");                if(!u) return; currentUser = u; localStorage.setItem('jM_user', u); alert("TITAN OVERRIDE ACTIVE.");            } else { return; }        } else if(mode === '1') {            const u = prompt("Identity Name:"), p = prompt("Security Key:");            const data = await bridgeRead(DB_URL + "users/" + u + ".json");            if(data && (String(data.pass) === String(p))) {                currentUser = String(u); userPfp = data.pfp || userPfp; vaultContent = data.vault || ""; localStorage.setItem('jM_user', currentUser);            } else { alert("DENIED"); return; }        } else if(mode === '2') {            const u = prompt("Create Identity Name:"), p = prompt("Create Identity Key:");            await bridgeWrite(DB_URL + "users/" + u + ".json", 'PUT', {pass: String(p), pfp: userPfp, vault: ""});            currentUser = u; localStorage.setItem('jM_user', u); alert("IDENTITY ARCHIVED.");        }        if(prompt("SYSTEM ACCESS KEY:") !== "ATAPI.SYS") return;        runBoot();    }    function runBoot() {        const l = d.createElement('div');        l.style = 'position:fixed;top:0;left:0;width:100%;height:100%;background:#000;z-index:2147483647;display:flex;flex-direction:column;justify-content:center;align-items:center;color:#ffaa00;font-family:monospace;';        l.innerHTML = '<div style="text-align:center;padding:120px;border:3px solid #ffaa00;background:#050505;box-shadow:0 0 300px #ffaa0022;border-radius:5px;">' +            '<h1 style="letter-spacing:35px;margin:0;text-shadow:0 0 30px #ffaa00;font-size:50px;font-weight:900;">jeroniMO</h1><p style="opacity:0.6;margin-top:20px;letter-spacing:8px;">OMEGA TITAN V5.2 | THE MONOLITH</p>' +            '<div style="width:550px;height:4px;background:#111;margin:60px 0;position:relative;"><div id="j-bar" style="width:0%;height:100%;background:#ffaa00;box-shadow:0 0 40px #ffaa00;transition:0.1s;"></div></div>' +            '<div id="j-status" style="font-size:12px;text-transform:uppercase;letter-spacing:5px;color:#ffaa00;">Calibrating Neural Sync...</div></div>';        d.body.appendChild(l);        let p = 0; const i = setInterval(() => { p++; d.getElementById('j-bar').style.width = p+'%'; if(p>=100){clearInterval(i); l.remove(); initPanel();} }, 15);    }    function initPanel() {        const p = d.createElement('div');        p.id = 'jeroniMO-panel';        p.style = 'position:fixed;top:5px;right:5px;width:450px;height:950px;max-height:98vh;background:#030303;color:#ffaa00;z-index:2147483640;border:2px solid #222;box-shadow:40px 40px 0 #000;display:flex;flex-direction:column;font-family:monospace;overflow:hidden;border-radius:2px;';                const h = d.createElement('div');        h.style = 'cursor:move;background:#111;padding:25px;display:flex;justify-content:space-between;align-items:center;border-bottom:3px solid #ffaa00;';        h.innerHTML = '<div style="display:flex;align-items:center;gap:15px;"><div style="width:14px;height:14px;background:#ffaa00;box-shadow:0 0 15px #ffaa00;"></div><b style="letter-spacing:5px;font-size:18px;">TITAN OVERLORD</b></div>' +        '<div><button id="j-logout" style="background:#330000;border:1px solid #ff4444;color:#ff4444;padding:4px 10px;font-size:11px;cursor:pointer;margin-right:15px;font-weight:bold;">TERMINATE</button>' +        '<button id="j-min" style="background:none;border:1px solid #ffaa00;padding:2px 15px;cursor:pointer;margin-right:10px;color:#ffaa00;font-weight:bold;">_</button>' +        '<button id="j-close" style="background:#ff4444;color:#000;border:none;padding:2px 15px;cursor:pointer;font-weight:bold;">X</button></div>';        p.appendChild(h);        const s = d.createElement('div');        s.style = 'flex:1;overflow-y:auto;padding:30px;display:flex;flex-direction:column;gap:30px;scrollbar-width:none;background:radial-gradient(circle at top right, #0a0a0a, #000);';        p.appendChild(s);        /* --- OVERLORD IDENTITY BLOCK (RESTORED) --- */        const prof = d.createElement('div');        prof.style = 'background:rgba(255,170,0,0.02);border:1px solid #222;padding:30px;display:flex;align-items:center;gap:30px;';        prof.innerHTML = %60<div style="position:relative;"><img id="j-pfp-img" src="${userPfp}" style="width:110px;height:110px;border-radius:2px;border:2px solid #ffaa00;object-fit:cover;box-shadow:0 0 30px #000;">%60 +        %60<button id="pfp-up" style="position:absolute;bottom:-10px;right:-10px;background:#ffaa00;border:none;width:35px;height:35px;cursor:pointer;font-weight:bold;color:#000;box-shadow:0 0 15px #000;">+</button></div>%60 +        %60<div><b style="font-size:32px;color:#fff;text-shadow:0 0 10px #ffaa0033;">${currentUser}</b><small style="color:#