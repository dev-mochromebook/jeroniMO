s.appendChild(chatWrap);        /* --- CLOUD VAULT --- */        const vault = d.createElement('div');        vault.style = 'background:#000;border:1px solid #222;padding:20px;';        vault.innerHTML = '<b style="color:#00ccff;letter-spacing:2px;">[☁%EF%B8%8F] CLOUD VAULT (SYNC-CORE)</b><textarea id="j-vault-input" style="width:100%;height:120px;background:#010101;color:#00ccff;border:1px solid #002233;margin:15px 0;font-family:monospace;box-sizing:border-box;padding:15px;font-size:12px;outline:none;resize:none;">${vaultContent}</textarea>' +        '<button id="save-vault" style="width:100%;background:#001122;color:#00ccff;border:1px solid #00ccff;padding:15px;cursor:pointer;font-weight:bold;font-size:11px;letter-spacing:2px;">UPLOAD TO TITAN DATABASE</button>';        s.appendChild(vault);        /* --- COMMAND LAB --- */        const lab = d.createElement('div');        lab.style = 'background:#000;border:1px solid #222;padding:20px;';        lab.innerHTML = '<b style="color:lime;letter-spacing:2px;">[>] COMMAND LAB (OMEGA PAYLOAD)</b><textarea id="j-js" style="width:100%;height:120px;background:#010101;color:lime;border:1px solid #003300;margin:15px 0;font-family:monospace;box-sizing:border-box;padding:15px;font-size:12px;outline:none;resize:none;" placeholder="// Execute core commands..."></textarea>' +        '<button id="run-js" style="width:100%;background:#003300;color:lime;border:1px solid lime;padding:18px;cursor:pointer;font-weight:bold;text-transform:uppercase;letter-spacing:3px;">Deploy Payload</button>';        s.appendChild(lab);        /* --- CHAOS MANIFEST --- */        const pg = d.createElement('div');        pg.style = 'background:#000;border:1px solid #222;padding:20px;';        pg.innerHTML = '<div style="display:flex;justify-content:space-between;"><b style="color:red;letter-spacing:2px;">[!] GLOBAL CHAOS MANIFEST</b><label style="color:#fff;font-size:10px;"><input type="checkbox" id="j-broadcast"> BROADCAST</label></div>' +        '<div id="j-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-top:20px;"></div>';        s.appendChild(pg);        const pranks = [            {n:'Pixel Corrupt', f: () => startPixelCorruption()},            {n:'Chaos Spin', s:'body{animation:jS 3s linear infinite}@keyframes jS{to{transform:rotate(360deg)}}'},            {n:'Acid Trip', s:'body{animation:jA 0.5s infinite}@keyframes jA{0%{filter:hue-rotate(0deg)}100%{filter:hue-rotate(360deg)}}'},            {n:'Matrix Mode', s:'*{background:#000 !important; color:#0f0 !important; font-family:monospace !important;}'},            {n:'Ghost UI', s:'body{opacity:0.2; filter:blur(6px); transition:4s;}'},            {n:'Earthquake', s:'body{animation:jH .02s infinite}@keyframes jH{0%{top:3px;left:3px}50%{top:-3px;left:-3px}}body{position:relative}'},            {n:'Gravity Fail', s:'*{transition:8s; transform:translateY(2000px) rotate(180deg);}'},            {n:'Blinking Panic', s:'body{animation:jP 0.1s infinite;} @keyframes jP{0%{opacity:1} 50%{opacity:0} 100%{opacity:1}}'}        ];        pranks.forEach(pr => {            const b = d.createElement('button'); b.innerText = pr.n;            b.style = 'background:#080808;color:#fff;border:1px solid #222;padding:18px;cursor:pointer;font-size:11px;font-weight:bold;transition:0.3s;';            b.onclick = async () => {                if(d.getElementById('j-broadcast').checked) { await bridgeWrite(DB_URL + "global_chaos.json", 'PUT', {command: pr.n, user: currentUser, time: Date.now()}); }                if(pr.f) { pr.f(); b.style.borderColor='red'; }                 else {                    const sid='s-'+pr.n.replace(/\s+/g, '');                    if(d.getElementById(sid)){ d.getElementById(sid).remove(); b.style.borderColor='#222'; b.style.color='#fff'; }                    else { const st=d.createElement('style'); st.id=sid; st.textContent=pr.s; d.head.appendChild(st); b.style.borderColor='#ffaa00'; b.style.color='#ffaa00'; }                }            };            pg.querySelector('#j-grid').appendChild(b);        });        d.body.appendChild(p);        /* --- LOGIC CONTROLLERS --- */        const chatBox = d.getElementById('j-chat-box');        async function updateChat() {            const m = await bridgeRead(DB_URL + "chat.json");            if(m) { chatBox.innerHTML = Object.values(m).slice(-20).map(msg => %60<div><b style="color:#ffaa00;">${msg.user}:</b> ${msg.text}</div>%60).join(''); chatBox.scrollTop = chatBox.scrollHeight; }        }        d.getElementById('j-chat-send').onclick = async () => {            const t = d.getElementById('j-chat-in').value; if(!t) return;            await bridgeWrite(DB_URL + "chat/" + Date.now() + ".json", 'PUT', {user: currentUser, text: t});            d.getElementById('j-chat-in').value = ""; updateChat();        };        setInterval(updateChat, 4000);        d.getElementById('sh-links').onclick = () => { d.getElementById('j-shell-out').innerText = "[MAPPING LINKS...]\n" + Array.from(d.querySelectorAll('a')).map(a => a.href).slice(0, 30).join('\n'); };        d.getElementById('sh-js').onclick = () => { d.getElementById('j-shell-out').innerText = "[MAPPING SCRIPTS...]\n" + Array.from(d.querySelectorAll('script')).map(s => s.src).filter(s=>s).slice(0, 30).join('\n'); };        d.getElementById('run-js').onclick = () => { try { eval(d.getElementById('j-js').value); } catch(e){alert(e);} };        d.getElementById('save-vault').onclick = async () => { await bridgeWrite(DB_URL + "users/" + currentUser + "/vault.json", 'PUT', d.getElementById('j-vault-input').value); alert("TITAN CLOUD SYNCED."); };        d.getElementById('j-logout').onclick = () => { localStorage.clear(); location.reload(); };        d.getElementById('j-min').onclick = () => { p.style.height = p.style.height === '75px' ? '950px' : '75px'; };        d.getElementById('j-close').onclick = () => p.remove();        const up = d.createElement('input'); up.type='file'; up.accept='image/*';        d.getElementBy